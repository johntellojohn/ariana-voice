NODE_ENV=production

# Puerto interno del contenedor. Normalmente no hace falta cambiarlo.
PORT=3001

# Puerto publico del servidor. Si tu firewall tiene abierto el 328, usa 328.
HOST_PORT=328

APP_NAME=Ariana Voice Gateway
PUBLIC_BASE_URL=http://TU_IP_O_DOMINIO:328
CORS_ORIGINS=*

# Si Laravel esta en otro dominio, usa https://tudominio.com
# Si Laravel esta en otro contenedor de la misma red, usa http://nombre-servicio:80
# Evita http://localhost aqui: dentro de Docker apunta al propio contenedor Node.
LARAVEL_API_URL=https://TU_DOMINIO_LARAVEL
LARAVEL_API_TOKEN=

OPENAI_API_KEY=tu_api_key_de_openai
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
NORMALIZE_MP3_WITH_FFMPEG=true

# Obligatorio recomendado en produccion.
VOICE_API_TOKEN=un_token_largo_y_privado

MAX_AUDIO_UPLOAD_MB=25
TMP_DIR=tmp
AUDIO_UPLOAD_DIR=tmp/uploads
TTS_OUTPUT_DIR=tmp/tts

LOG_LEVEL=info
