NODE_ENV=production

# Puerto interno del contenedor. Normalmente no hace falta cambiarlo.
PORT=3001

# Puerto publico del servidor. Si tu firewall tiene abierto el 328, usa 328.
HOST_PORT=328

APP_NAME=Ariana Voice Gateway
PUBLIC_BASE_URL=http://TU_IP_O_DOMINIO:328
CORS_ORIGINS=*

# Si Laravel esta en otro dominio, usa https://tudominio.com
# Si Laravel esta en otro contenedor de la misma red, usa http://nombre-servicio:80
# Evita http://localhost aqui: dentro de Docker apunta al propio contenedor Node.
LARAVEL_API_URL=https://TU_DOMINIO_LARAVEL
LARAVEL_API_TOKEN=

OPENAI_API_KEY=tu_api_key_de_openai
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
NORMALIZE_MP3_WITH_FFMPEG=true

# Obligatorio recomendado en produccion.
VOICE_API_TOKEN=un_token_largo_y_privado

MAX_AUDIO_UPLOAD_MB=25
TMP_DIR=tmp
AUDIO_UPLOAD_DIR=tmp/uploads
TTS_OUTPUT_DIR=tmp/tts

# Para WebRTC real en Docker, usa TURN o red host/UDP accesible.
# Ejemplo TURN:
# WEBRTC_ICE_SERVERS=[{"urls":["turn:turn.example.com:3478"],"username":"user","credential":"pass"}]
WEBRTC_ICE_SERVERS=[]
WEBRTC_ICE_GATHER_TIMEOUT_MS=3000
CALL_AUDIO_LANGUAGE=es
CALL_ALLOW_LANGUAGE_OVERRIDE=false
CALL_STT_TEMPERATURE=0
CALL_STT_PROMPT=Transcribe audio de una llamada de WhatsApp en espanol latino. No traduzcas al ingles. Conserva palabras cortas comunes como hola, donde, vale, gracias, cita y agenda. Si el audio no es claro, devuelve la mejor transcripcion en espanol.
CALL_CALLBACK_TIMEOUT_MS=30000
CALL_TURN_RMS_THRESHOLD=0.015
CALL_TURN_SILENCE_MS=900
CALL_TURN_MIN_SPEECH_MS=450
CALL_TURN_MAX_MS=15000
CALL_SILENCE_FRAME_MS=10
CALL_LOG_SDP=true
CALL_PLAYBACK_WAIT_FOR_ICE_MS=5000

LOG_LEVEL=info
