NODE_ENV=development
PORT=3001
HOST_PORT=3001

APP_NAME=Ariana Voice Gateway
PUBLIC_BASE_URL=http://localhost:3001
CORS_ORIGINS=*

LARAVEL_API_URL=http://localhost
LARAVEL_API_TOKEN=

OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
NORMALIZE_MP3_WITH_FFMPEG=true

VOICE_API_TOKEN=
MAX_AUDIO_UPLOAD_MB=25
TMP_DIR=tmp
AUDIO_UPLOAD_DIR=tmp/uploads
TTS_OUTPUT_DIR=tmp/tts

WEBRTC_ICE_SERVERS=[]
WEBRTC_ICE_GATHER_TIMEOUT_MS=3000
CALL_AUDIO_LANGUAGE=es
CALL_ALLOW_LANGUAGE_OVERRIDE=false
CALL_STT_TEMPERATURE=0
CALL_STT_PROMPT=Transcribe audio de una llamada de WhatsApp en espanol latino. No traduzcas al ingles. Conserva palabras cortas comunes como hola, donde, vale, gracias, cita y agenda. Si el audio no es claro, devuelve la mejor transcripcion en espanol.
CALL_CALLBACK_TIMEOUT_MS=30000
CALL_TURN_RMS_THRESHOLD=0.015
CALL_TURN_SILENCE_MS=900
CALL_TURN_MIN_SPEECH_MS=450
CALL_TURN_MAX_MS=15000
CALL_SILENCE_FRAME_MS=10
CALL_SILENCE_LOG_EVERY_FRAMES=6000
CALL_IDLE_TIMEOUT_MS=60000
CALL_MAX_DURATION_MS=1800000
CALL_POST_PLAYBACK_MUTE_MS=800
CALL_LOG_SDP=true
CALL_PLAYBACK_WAIT_FOR_ICE_MS=5000

PBX_AMI_ENABLED=false
PBX_AMI_HOST=127.0.0.1
PBX_AMI_PORT=5038
PBX_AMI_USERNAME=
PBX_AMI_PASSWORD=
PBX_AMI_RECONNECT=true
PBX_MAX_EVENTS=300
PBX_ORIGINATE_CONTEXT=from-internal
PBX_ORIGINATE_PRIORITY=1
PBX_ORIGINATE_TIMEOUT_MS=30000
PBX_CALLER_ID_PREFIX=Ariana
PBX_DIRECT_TRUNK_ENDPOINT=fxo
PBX_LARAVEL_EVENTS_ENABLED=false
PBX_LARAVEL_EVENTS_PATH=/api/trunk-calls/events

LOG_LEVEL=debug
