NODE_ENV=development
PORT=3001
HOST_PORT=3001

APP_NAME=Ariana Voice Gateway
PUBLIC_BASE_URL=http://localhost:3001
CORS_ORIGINS=*

LARAVEL_API_URL=http://localhost
LARAVEL_API_TOKEN=

OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
NORMALIZE_MP3_WITH_FFMPEG=true

VOICE_API_TOKEN=
MAX_AUDIO_UPLOAD_MB=25
TMP_DIR=tmp
AUDIO_UPLOAD_DIR=tmp/uploads
TTS_OUTPUT_DIR=tmp/tts

WEBRTC_ICE_SERVERS=[]
WEBRTC_ICE_GATHER_TIMEOUT_MS=3000
CALL_AUDIO_LANGUAGE=es
CALL_CALLBACK_TIMEOUT_MS=30000
CALL_TURN_RMS_THRESHOLD=0.015
CALL_TURN_SILENCE_MS=900
CALL_TURN_MIN_SPEECH_MS=450
CALL_TURN_MAX_MS=15000
CALL_SILENCE_FRAME_MS=10

LOG_LEVEL=debug
